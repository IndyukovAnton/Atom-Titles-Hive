# Atom-Titles-Hive environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# JWT — min 32 chars, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Database (dev uses repo-relative path; prod stores under OS app-data dir)
DATABASE_PATH=database/app.db

# Google OAuth (optional — strategy disabled if any of these are missing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3553/auth/google/callback

# Server
PORT=3553
NODE_ENV=development
FRONTEND_URL=http://localhost:5005

# TypeORM (synchronize honored only in development)
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true

# Logging
LOG_RETENTION_DAYS=30
