# Backend environment template.
# Copy to `backend/.env` and fill in real values. NEVER commit `backend/.env`.

# Server Configuration
PORT=1221
NODE_ENV=development # development | production | test

# JWT — min 32 chars, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Database
# Dev: path below is resolved relative to the repo root.
# Prod: the app auto-stores DB under OS app-data dir (e.g. %APPDATA%/AtomTitlesHive/app.db).
DATABASE_PATH=database/app.db

# TypeORM (synchronize honored only when NODE_ENV=development)
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true

# Google OAuth (optional — strategy disabled if any of these are missing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:1221/auth/google/callback

# Frontend base URL (used for OAuth redirect back to UI)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_RETENTION_DAYS=30
