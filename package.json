{
  "name": "seen",
  "private": true,
  "version": "0.2.1",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "cd backend && npm run build",
    "build:backend:sidecar": "cd backend && npm run pkg:build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "lint:backend": "npm --prefix backend run lint",
    "test:backend:ci": "npm --prefix backend run test:ci",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:frontend:ci": "npm --prefix frontend run test:ci",
    "check": "npm run lint:frontend && npm run test:frontend:ci && npm run lint:backend && npm run test:backend:ci && npm run build:all",
    "sync:version": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add frontend/package.json src-tauri/tauri.conf.json src-tauri/Cargo.toml",
    "setup:updater": "node scripts/setup-updater.mjs",
    "release:build": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml}": "prettier --write"
  }
}
