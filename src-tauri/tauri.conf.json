{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Seen",
  "version": "0.2.0",
  "identifier": "com.indyukov.seen",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5005",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "npm run build:frontend && npm run build:backend:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "Seen",
        "width": 1280,
        "height": 800,
        "minWidth": 400,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src 'self' http://localhost:* ws://localhost:*; img-src 'self' asset: data: blob: https:; media-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/IndyukovAnton/web-titles-tracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3MTAwRERBMkMwMzM3NDkKUldSSk53TXMyZzBRbHpoaTlyQXAwd0FUMmg5R0ZQRlhjajAxNzVMOWNOZGN4QjZsNUx1cm1pZHoK",
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
